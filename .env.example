# Configuration pour l'envoi des emails et notifications v2.15
# Copier ce fichier en .env et remplir les valeurs

# === SUPABASE ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# === EMAIL - Option 1: Gmail/SMTP ===
EMAIL_SERVICE=smtp
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_REPLY_TO=support@yourdomain.com

# === EMAIL - Option 2: SendGrid (alternative) ===
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=SG.your_sendgrid_key
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# === FIREBASE ===
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_DATABASE_URL=https://your-firebase-project.firebaseio.com

# === CONFIGURATION OPTIONNELLE ===
DELAY_BETWEEN_EMAILS_MS=500
DRY_RUN=false
LOG_LEVEL=info
